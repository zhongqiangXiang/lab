# Example .env configuration for issue-codex-automation

# Required: GitHub personal access token with repo scope
GITHUB_TOKEN=ghp_xxxxxxxxxxxxx

# Optional: Repository in format owner/repo (auto-detected from git remote if not set)
# GITHUB_REPO=owner/repo

# Optional: Directory for state and run artifacts (default: .codex_issue_agent)
# STATE_DIR=.codex_issue_agent

# Optional: Required label for issue eligibility (default: codex-ready)
# LABEL_FILTER=codex-ready

# Optional: Include issue comments in generated prompts (default: false)
# INCLUDE_COMMENTS=false
